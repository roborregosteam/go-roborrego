// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
    VIEWER
    MEMBER
    ADMIN
}

enum MemberStatus {
    ACTIVE
    INACTIVE
    ALUMNI
}

enum CompletionStatus {
    PENDING
    APPROVED
    REJECTED
}

enum AttendanceMethod {
    QR_CODE
    MANUAL
    SELF
}

enum ProjectStatus {
    ACTIVE
    COMPLETED
    ARCHIVED
}

enum ProjectRole {
    PROJECT_MEMBER
    PROJECT_MANAGER
}

enum TaskStatus {
    TODO
    IN_PROGRESS
    IN_REVIEW
    DONE
}

enum TaskPriority {
    LOW
    MEDIUM
    HIGH
    URGENT
}

// ─── NextAuth models ──────────────────────────────────────────────────────────

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    refresh_token_expires_in Int?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
    id             String       @id @default(cuid())
    name           String?
    email          String?      @unique
    emailVerified  DateTime?
    image          String?
    // Profile
    phone          String?
    bio            String?
    githubUsername String?
    linkedinUrl    String?
    graduationDate DateTime?
    birthday       DateTime?
    joinDate       DateTime     @default(now())
    subTeam        String?
    // RBAC
    role           Role         @default(VIEWER)
    status         MemberStatus @default(ACTIVE)
    lastLoginAt    DateTime?
    // Web export
    webId             Int?     @unique
    lastname          String?
    subtitle          String?
    semesters         Int?
    tags              String?
    excludeFromExport Boolean  @default(false)
    // Onboarding
    onboardingDismissed Boolean @default(false)
    // Microsoft integration (tokens never exposed to client)
    msAccessToken  String?
    msRefreshToken String?
    msTokenExpiry  DateTime?

    // NextAuth relations
    accounts Account[]
    sessions Session[]

    // Work plan relations
    workPlanInterests   WorkPlanInterest[]
    workPlanCompletions WorkPlanCompletion[]

    // Attendance relations
    meetingsCreated  Meeting[]          @relation("MeetingCreator")
    attendances      Attendance[]
    meetingFeedbacks MeetingFeedback[]

    // Project relations
    projectsCreated Project[]       @relation("ProjectCreator")
    projectMembers  ProjectMember[]
    tasksCreated     Task[]           @relation("TaskCreator")
    taskAssignments  TaskAssignee[]
    taskComments     TaskComment[]
    taskAttachments  TaskAttachment[]
    apiKey           ApiKey?
    profileEdits     ProfileEdit[]
    reviewedEdits    ProfileEdit[] @relation("ProfileEditReviewer")
}

// ─── Profile Edits ────────────────────────────────────────────────────────────

enum ProfileEditStatus {
    PENDING
    APPROVED
    REJECTED
}

model ProfileEdit {
    id             String            @id @default(cuid())
    userId         String
    status         ProfileEditStatus @default(PENDING)
    submittedAt    DateTime          @default(now())
    reviewedAt     DateTime?
    reviewedBy     String?
    reviewNote     String?

    // Proposed values — null means "no change proposed for this field"
    name           String?
    phone          String?
    bio            String?
    githubUsername String?
    linkedinUrl    String?
    subTeam        String?
    graduationDate DateTime?
    birthday       DateTime?

    user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
    reviewer User? @relation("ProfileEditReviewer", fields: [reviewedBy], references: [id])

    @@index([userId, status])
    @@index([status])
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model ApiKey {
    id         String    @id @default(cuid())
    userId     String    @unique
    keyHash    String    @unique // SHA-256 of the plain token
    createdAt  DateTime  @default(now())
    expiresAt  DateTime
    lastUsedAt DateTime?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Work Plan ────────────────────────────────────────────────────────────────

model Semester {
    id        String   @id @default(cuid())
    name      String // e.g., "Spring 2026"
    startDate DateTime
    endDate   DateTime
    isActive  Boolean  @default(false)
    createdAt DateTime @default(now())

    activities WorkPlanActivity[]
}

model WorkPlanActivity {
    id            String    @id @default(cuid())
    semesterId    String
    name          String
    description   String
    points        Int
    estimatedDate DateTime?
    adminMessage  String? // What the member is expected to submit
    isMandatory   Boolean   @default(false)
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    semester    Semester             @relation(fields: [semesterId], references: [id])
    interests   WorkPlanInterest[]
    completions WorkPlanCompletion[]

    @@index([semesterId])
}

model WorkPlanInterest {
    id         String   @id @default(cuid())
    userId     String
    activityId String
    createdAt  DateTime @default(now())

    user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity WorkPlanActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([userId, activityId])
}

model WorkPlanCompletion {
    id         String           @id @default(cuid())
    userId     String
    activityId String
    note       String
    status     CompletionStatus @default(PENDING)
    adminNote  String?
    createdAt  DateTime         @default(now())
    updatedAt  DateTime         @updatedAt

    user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity WorkPlanActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([activityId])
}

// ─── Attendance ────────────────────────────────────────────────────────────────

model Meeting {
    id                  String   @id @default(cuid())
    title               String
    description         String?
    notes               String?
    notesAllowAttendees Boolean  @default(false)
    startTime           DateTime
    duration            Int // minutes
    checkInToken        String   @unique @default(cuid())
    createdBy           String
    projectId           String?
    teamsChannelId      String?
    teamsJoinUrl        String?
    outlookEventId      String?
    createdAt           DateTime @default(now())

    creator     User              @relation("MeetingCreator", fields: [createdBy], references: [id])
    project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
    attendances Attendance[]
    feedbacks   MeetingFeedback[]

    @@index([startTime])
    @@index([projectId])
}

model MeetingFeedback {
    id          String   @id @default(cuid())
    meetingId   String
    userId      String
    rating      Int? // 1–5
    comment     String?
    isAnonymous Boolean  @default(false)
    createdAt   DateTime @default(now())

    meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, meetingId])
    @@index([meetingId])
}

model Attendance {
    id          String           @id @default(cuid())
    userId      String
    meetingId   String
    checkInTime DateTime         @default(now())
    method      AttendanceMethod @default(SELF)
    note        String?
    isLate      Boolean          @default(false)

    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

    @@unique([userId, meetingId])
    @@index([userId])
    @@index([meetingId])
}

// ─── Projects ──────────────────────────────────────────────────────────────────

model Project {
    id          String        @id @default(cuid())
    name        String
    description String?
    subTeam     String?
    status      ProjectStatus @default(ACTIVE)
    isPrivate   Boolean       @default(false)
    startDate   DateTime?
    endDate     DateTime?
    githubRepo  String?
    createdBy   String
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt

    creator  User            @relation("ProjectCreator", fields: [createdBy], references: [id])
    members  ProjectMember[]
    tasks    Task[]
    meetings Meeting[]

    @@index([status])
}

model ProjectMember {
    id        String      @id @default(cuid())
    projectId String
    userId    String
    role      ProjectRole @default(PROJECT_MEMBER)
    addedAt   DateTime    @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([projectId, userId])
    @@index([projectId])
    @@index([userId])
}

model Task {
    id          String       @id @default(cuid())
    projectId   String
    title       String
    description String?
    status      TaskStatus   @default(TODO)
    priority    TaskPriority @default(MEDIUM)
    dueDate     DateTime?
    labels      String[]
    createdBy   String
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt

    project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
    creator   User           @relation("TaskCreator", fields: [createdBy], references: [id])
    assignees    TaskAssignee[]
    comments     TaskComment[]
    attachments  TaskAttachment[]

    @@index([projectId])
    @@index([status])
}

model TaskAssignee {
    taskId String
    userId String

    task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([taskId, userId])
}

model TaskComment {
    id        String   @id @default(cuid())
    taskId    String
    userId    String
    content   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([taskId])
}

model TaskAttachment {
    id           String   @id @default(cuid())
    taskId       String
    userId       String
    fileName     String
    fileUrl      String
    storagePath  String
    fileSize     Int
    mimeType     String
    createdAt    DateTime @default(now())

    task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([taskId])
}
